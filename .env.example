# Smart Hostel Management System - Environment Configuration
# Copy this file to .env and update with your values

# ============= DATABASE CONFIGURATION =============
DB_NAME=SmartHostelDB
DB_USER=postgres
DB_PASSWORD=SecurePassword123!
DB_PORT=5432

# ============= REDIS CONFIGURATION =============
REDIS_PASSWORD=RedisSecure123!
REDIS_PORT=6379

# ============= APPLICATION PORTS =============
APP_PORT_HTTP=5000
APP_PORT_HTTPS=5001

# ============= ASP.NET CORE CONFIGURATION =============
ASPNETCORE_ENVIRONMENT=Production
LOG_LEVEL=Information
LOG_LEVEL_ASPNET=Warning

# ============= JWT CONFIGURATION =============
# Generate a new secret key (min 32 characters)
JWT_SECRET_KEY=your-production-secret-key-minimum-32-characters-required
JWT_ISSUER=SmartHostelAPI
JWT_AUDIENCE=SmartHostelClient
JWT_EXPIRES_HOURS=24

# ============= PGADMIN CONFIGURATION =============
PGADMIN_EMAIL=admin@smarthostel.com
PGADMIN_PASSWORD=AdminPassword123!
PGADMIN_PORT=5050

# ============= COMPOSE PROJECT NAME =============
COMPOSE_PROJECT_NAME=smarthostel
